    "dotenv": "^17.4.2",
    "grammy": "^1.44.0",
    "node-cron": "^4.6.0",
    "pdfmake": "^0.3.11",
    "pptxgenjs": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
